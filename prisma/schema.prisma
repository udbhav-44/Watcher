generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id               String         @id @default(cuid())
  titleId          String         @unique
  title            String
  synopsis         String?
  backdropUrl      String?
  posterUrl        String?
  releaseYear      Int?
  durationMinutes  Int?
  maturityRating   String?
  trailerUrl       String?
  playableUrl      String
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  genres           MovieGenre[]
  cast             CastMember[]
  featuredInRails  FeaturedRailMovie[]
}

model Genre {
  id      String      @id @default(cuid())
  name    String      @unique
  movies  MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model CastMember {
  id         String @id @default(cuid())
  movieId    String
  name       String
  character  String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  movie      Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model WatchEvent {
  id             String   @id @default(cuid())
  titleId         String
  profileKey      String
  mediaType       String   @default("movie")
  season          Int?
  episode         Int?
  secondsWatched  Int      @default(0)
  progressPercent Float    @default(0)
  completed       Boolean  @default(false)
  watchedAt       DateTime @default(now())

  @@index([titleId])
  @@index([profileKey, titleId])
  @@index([profileKey, watchedAt])
}

model Collection {
  id         String           @id @default(cuid())
  profileKey String
  name       String
  slug       String
  isDefault  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  items      CollectionItem[]

  @@unique([profileKey, slug])
  @@index([profileKey])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  titleId      String
  mediaType    String     @default("movie")
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, titleId])
  @@index([titleId])
}

model Rating {
  id         String   @id @default(cuid())
  profileKey String
  titleId    String
  mediaType  String   @default("movie")
  score      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([titleId, profileKey])
  @@index([profileKey, score])
  @@index([titleId])
}

model SearchHistoryEntry {
  id         String   @id @default(cuid())
  profileKey String
  query      String
  createdAt  DateTime @default(now())

  @@index([profileKey, createdAt])
}

model Reaction {
  id         String   @id @default(cuid())
  titleId    String
  profileKey String
  type       ReactionType
  createdAt  DateTime @default(now())

  @@unique([titleId, profileKey])
}

enum ReactionType {
  LIKE
  FIRE
  WOW
}

model FeaturedRail {
  id         String              @id @default(cuid())
  slug       String              @unique
  label      String
  sortOrder  Int                 @default(0)
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  movies     FeaturedRailMovie[]
}

model FeaturedRailMovie {
  featuredRailId String
  movieId        String
  sortOrder      Int      @default(0)
  featuredRail   FeaturedRail @relation(fields: [featuredRailId], references: [id], onDelete: Cascade)
  movie          Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([featuredRailId, movieId])
}

model AdminAudit {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
}

model UserProfile {
  key        String   @id
  displayName String
  avatarColor String? @default("#5ee3ff")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model UserPreferences {
  profileKey       String   @id
  theme            String   @default("dark")
  density          String   @default("comfortable")
  reducedMotion    Boolean  @default(false)
  defaultProvider  String   @default("vidking")
  subtitleLanguage String   @default("en")
  voiceSearch      Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model SkipMarker {
  id          String   @id @default(cuid())
  profileKey  String
  titleId     String
  season      Int?
  episode     Int?
  kind        String   @default("intro")
  endSeconds  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([profileKey, titleId, season, episode, kind])
  @@index([profileKey, titleId])
}

model FeaturedTheme {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  coverUrl    String?
  accent      String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  items       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}
