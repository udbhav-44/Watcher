generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id               String         @id @default(cuid())
  titleId          String         @unique
  title            String
  synopsis         String?
  backdropUrl      String?
  posterUrl        String?
  releaseYear      Int?
  durationMinutes  Int?
  maturityRating   String?
  trailerUrl       String?
  playableUrl      String
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  genres           MovieGenre[]
  cast             CastMember[]
  watchEvents      WatchEvent[]
  watchlistItems   WatchlistItem[]
  reactions        Reaction[]
  featuredInRails  FeaturedRailMovie[]
}

model Genre {
  id      String      @id @default(cuid())
  name    String      @unique
  movies  MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model CastMember {
  id         String @id @default(cuid())
  movieId    String
  name       String
  character  String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  movie      Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model WatchEvent {
  id             String   @id @default(cuid())
  movieId         String
  profileKey      String
  secondsWatched  Int      @default(0)
  progressPercent Float    @default(0)
  completed       Boolean  @default(false)
  watchedAt       DateTime @default(now())
  movie           Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([profileKey, watchedAt])
}

model WatchlistItem {
  id         String   @id @default(cuid())
  movieId     String
  profileKey  String
  createdAt   DateTime @default(now())
  movie       Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, profileKey])
}

model Reaction {
  id         String   @id @default(cuid())
  movieId    String
  profileKey String
  type       ReactionType
  createdAt  DateTime @default(now())
  movie      Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, profileKey])
}

enum ReactionType {
  LIKE
  FIRE
  WOW
}

model FeaturedRail {
  id         String              @id @default(cuid())
  slug       String              @unique
  label      String
  sortOrder  Int                 @default(0)
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  movies     FeaturedRailMovie[]
}

model FeaturedRailMovie {
  featuredRailId String
  movieId        String
  sortOrder      Int      @default(0)
  featuredRail   FeaturedRail @relation(fields: [featuredRailId], references: [id], onDelete: Cascade)
  movie          Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@id([featuredRailId, movieId])
}

model AdminAudit {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
}
